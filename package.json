{
  "name": "exam-session-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "client:dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "nodemon",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "electron:dev": "npm run build:all && electron .",
    "electron:start": "npm run build:all && electron .",
    "build:api": "tsc --outDir dist-electron/api --rootDir api --module commonjs --moduleResolution node --target ES2020 --esModuleInterop --skipLibCheck --resolveJsonModule api/server.ts api/app.ts api/db.ts api/routes/operators.ts api/routes/rooms.ts api/routes/sessions.ts api/routes/students.ts api/routes/seats.ts api/routes/checkins.ts api/routes/anomalies.ts api/routes/audit.ts api/routes/export.ts api/routes/system.ts api/routes/wizard.ts api/routes/auth.ts && node -e \"require('fs').copyFileSync('api/package.json','dist-electron/api/package.json')\"",
    "build:electron-main": "tsc -p tsconfig.electron.json && node -e \"require('fs').copyFileSync('electron/package.json','dist-electron/package.json')\"",
    "build:all": "vite build && npm run build:electron-main && npm run build:api",
    "verify": "node scripts/verify-chains.mjs",
    "smoke-test": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^9.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "build": {
    "appId": "com.exam-session-manager.app",
    "productName": "培训考场管理系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": "portable"
    }
  }
}
